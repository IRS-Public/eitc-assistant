    <Fact path="/eitcPhaseOutThreshold2025">
      <Name>EITC phaseout amount threshold</Name>
      <Description>The amount of income above which the amount of EITC begins to be reduced.
          Rev Proc .06 Earned Income
          Credit &#xA7;32(b)
      </Description>
      <TaxYear>2025</TaxYear>
      <Derived>
        <Switch>
          <Case>
            <When>
              <Any>
                <Dependency path="/isFilingStatusSingle"/>
                <Dependency path="/isFilingStatusHOH"/>
                <Dependency path="/isFilingStatusQSS"/>
                <Dependency path="/isFilingStatusMFS"/>
              </Any>
            </When>
            <Then>
              <Switch>
                <Case>
                  <When>
                    <Equal>
                      <Left>
                        <Dependency path="/eitcQualifyingChildren"/>
                      </Left>
                      <Right>
                        <Int>0</Int>
                      </Right>
                    </Equal>
                  </When>
                  <Then>
                    <Dependency path="/eitcPhaseOutThreshold0QCNonMFJ2025"/>
                  </Then>
                </Case>
                <Case>
                  <When>
                    <GreaterThanOrEqual>
                      <Left>
                        <Dependency path="/eitcQualifyingChildren"/>
                      </Left>
                      <Right>
                        <Int>1</Int>
                      </Right>
                    </GreaterThanOrEqual>
                  </When>
                  <Then>
                    <Dependency path="/eitcPhaseOutThreshold1OrMoreQCNonMFJ2025"/>
                  </Then>
                </Case>
              </Switch>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isFilingStatusMFJ"/>
            </When>
            <Then>
              <Switch>
                <Case>
                  <When>
                    <Equal>
                      <Left>
                        <Dependency path="/eitcQualifyingChildren"/>
                      </Left>
                      <Right>
                        <Int>0</Int>
                      </Right>
                    </Equal>
                  </When>
                  <Then>
                    <Dependency path="/eitcPhaseOutThreshold0QCMFJ2025"/>
                  </Then>
                </Case>
                <Case>
                  <When>
                    <GreaterThanOrEqual>
                      <Left>
                        <Dependency path="/eitcQualifyingChildren"/>
                      </Left>
                      <Right>
                        <Int>1</Int>
                      </Right>
                    </GreaterThanOrEqual>
                  </When>
                  <Then>
                    <Dependency path="/eitcPhaseOutThreshold1OrMoreQCMFJ2025"/>
                  </Then>
                </Case>
              </Switch>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
