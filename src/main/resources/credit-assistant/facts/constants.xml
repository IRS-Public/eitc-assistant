    <Fact path="/deductionForTraditionalIRAContributionMax">
      <Description>Max contribution for traditional IRAs (excluding payroll deductions) is $8000 per year. $7000 is the limit for those under 50, but we only know if someone is under 65 or not
        We are agnostic to filing status so double to 16000 and do not take MAGI into account for simplified computation
      </Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <Dependency path="/isTaxYear2023"/>
            </When>
            <Then>
              <Dependency path="/deductionForTraditionalIRAContributionMax2023"/>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isTaxYear2024"/>
            </When>
            <Then>
              <Dependency path="/deductionForTraditionalIRAContributionMax2024"/>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isTaxYear2025"/>
            </When>
            <Then>
              <Dependency path="/deductionForTraditionalIRAContributionMax2025"/>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isTaxYear2026"/>
            </When>
            <Then>
              <Dependency path="/deductionForTraditionalIRAContributionMax2026"/>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
