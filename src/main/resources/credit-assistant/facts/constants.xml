<?xml version="1.0"?>
<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/taxYearOptions">
      <Derived>
        <EnumOptions>
          <String>2025</String>
          <String>2024</String>
          <String>2023</String>
        </EnumOptions>
      </Derived>
    </Fact>
    <Fact path="/chosenTaxYear">
      <Writable>
        <Enum optionsPath="/taxYearOptions"/>
      </Writable>
    </Fact>
    <Fact path="/hasSelectedChosenTaxYear">
      <Description>True when the user has selected a tax year (chosenTaxYear is complete).</Description>
      <Derived>
        <IsComplete>
          <Dependency path="/chosenTaxYear"/>
        </IsComplete>
      </Derived>
    </Fact>
    <Fact path="/taxYear">
      <Description>Chosen tax year</Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <Equal>
                <Left>
                  <Dependency path="/chosenTaxYear"/>
                </Left>
                <Right>
                  <Enum optionsPath="/taxYearOptions">2025</Enum>
                </Right>
              </Equal>
            </When>
            <Then>
              <Int>2025</Int>
            </Then>
          </Case>
          <Case>
            <When>
              <Equal>
                <Left>
                  <Dependency path="/chosenTaxYear"/>
                </Left>
                <Right>
                  <Enum optionsPath="/taxYearOptions">2024</Enum>
                </Right>
              </Equal>
            </When>
            <Then>
              <Int>2024</Int>
            </Then>
          </Case>
          <Case>
            <When>
              <Equal>
                <Left>
                  <Dependency path="/chosenTaxYear"/>
                </Left>
                <Right>
                  <Enum optionsPath="/taxYearOptions">2023</Enum>
                </Right>
              </Equal>
            </When>
            <Then>
              <Int>2023</Int>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/nextTaxYear">
      <Description>Next tax year</Description>
      <Derived>
        <Add>
          <Dependency path="/taxYear"/>
          <Int>1</Int>
        </Add>
      </Derived>
    </Fact>
    <Fact path="/lastTaxYear">
      <Description>Previous tax year</Description>
      <Derived>
        <Subtract>
          <Minuend>
            <Dependency path="/taxYear"/>
          </Minuend>
          <Subtrahends>
            <Int>1</Int>
          </Subtrahends>
        </Subtract>
      </Derived>
    </Fact>
    <Fact path="/taxYearMinusTwo">
      <Description>Tax year minus two years</Description>
      <Derived>
        <Subtract>
          <Minuend>
            <Dependency path="/taxYear"/>
          </Minuend>
          <Subtrahends>
            <Int>2</Int>
          </Subtrahends>
        </Subtract>
      </Derived>
    </Fact>
    <Fact path="/isTaxYear2023">
      <Derived>
        <Equal>
          <Left>
            <Dependency path="/taxYear"/>
          </Left>
          <Right>
            <Int>2023</Int>
          </Right>
