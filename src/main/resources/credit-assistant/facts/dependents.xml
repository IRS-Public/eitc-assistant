<?xml version="1.0"?>
<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/homeUpkeepScenarioOptions">
      <Name>Home Upkeep Scenario</Name>
      <Description>Identifies the taxpayer's living/financial situation regarding home maintenance costs.</Description>
      <Derived>
        <EnumOptions>
          <String>livedWithDependent</String>
          <String>custodialParentNonDependent</String>
          <String>dependentParentElsewhere</String>
          <String>none</String>
        </EnumOptions>
      </Derived>
    </Fact>
    <Fact path="/homeUpkeepScenario">
      <Name>Filing status</Name>
      <Description>The filing status selected by the taxpayer.</Description>
      <Writable>
        <Enum optionsPath="/homeUpkeepScenarioOptions"/>
      </Writable>
    </Fact>
    <Fact path="/tentativelyHOHFromHomeUpkeep">
      <Name>Paid more than half home costs without</Name>
      <Description>Derived boolean based on whether the user selected a qualifying scenario.</Description>
      <Derived>
        <Not>
          <Equal>
            <Left>
              <Dependency path="/homeUpkeepScenario"/>
            </Left>
            <Right>
              <Enum optionsPath="/homeUpkeepScenarioOptions">none</Enum>
            </Right>
          </Equal>
        </Not>
      </Derived>
    </Fact>
  </Facts>
</FactDictionaryModule>
