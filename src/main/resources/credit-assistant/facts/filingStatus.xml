<?xml version="1.0"?>
<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/filingStatusOptions">
      <Name>Filing Status Options</Name>
      <Description>Options for filing status</Description>
      <Derived>
        <EnumOptions>
          <String>marriedFilingJointly</String>
          <String>marriedFilingSeparately</String>
          <String>single</String>
          <String>headOfHousehold</String>
          <String>qualifiedSurvivingSpouse</String>
        </EnumOptions>
      </Derived>
    </Fact>
    <Fact path="/initialFilingStatus">
      <Name>Filing status</Name>
      <Description>The filing status selected by the taxpayer.</Description>
      <Writable>
        <Enum optionsPath="/filingStatusOptions"/>
      </Writable>
    </Fact>
    <Fact path="/knowsFilingStatus">
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/intendsToFileJointlyMFJ">
      <Name>Intends to file joint returns as MFJ</Name>
      <Description>Indicates if the taxpayer and spouse plan to file a joint return.</Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/intendsToFileJointlyWidow">
      <Name>Intends to file joint returns as a widow</Name>
      <Description>Indicates if the taxpayer will file a joint return with deceased spouse</Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/deceasedSpouseValidSSNOnDateOfDeath">
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/spouseAliveEndOfTaxYear">
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/intendsToFileJointly">
      <Description>Indicates if the taxpayer and spouse plan to file a joint return.</Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/intendsToFileJointlyMFJ"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/intendsToFileJointlyMFJ"/>
            </Then>
          </Case>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/intendsToFileJointlyWidow"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/intendsToFileJointlyWidow"/>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/spouseLivedWithTaxpayerLastSixMonths">
      <Name>Spouse lived with taxpayer last six months</Name>
      <Description>Indicates if the spouse lived in the home during the last 6 months of the year.</Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/paidMoreThanHalfHomeCostsForChild">
      <Name>Paid more than half home costs for child</Name>
      <Description>Indicates if the taxpayer paid &gt;50% of home costs where a qualifying child lived for the full year.</Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/entitledToPreviouslyFileJointReturn">
      <Description>Did the taxpayer file a joint return with their spouse for the year that died if it was before this taxpayer but not more than 2 years ago?</Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/canClaimChildAsDependentInCurrentTaxYear">
      <Description>If the taxpayer is entitled to a joint return with their spouse for the year that died if it was before this taxpayer but not more than 2 years ago and they paid more than half the upkeep costs during the current tax year</Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions">
      <Description>Can the child or step-child be claimed in the current tax year, with specific carveouts</Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/filingStatus">
      <Name>Filing status</Name>
      <Description>The filing status derived by EITC Assistant based on the chosen filing status and additional questions.</Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <Dependency path="/knowsFilingStatus"/>
            </When>
            <Then>
              <Dependency path="/initialFilingStatus"/>
            </Then>
          </Case>
          <Case>
            <When>
              <True/>
            </When>
            <Then>
              <Dependency path="/derivedFilingStatus"/>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/isFilingStatusComplete">
      <Derived>
        <IsComplete>
          <Dependency path="/filingStatus"/>
        </IsComplete>
      </Derived>
    </Fact>
    <Fact path="/flowReadableFilingStatus">
      <Name>Filing status that can be represented to the user in the flow, with correct spacing and casing</Name>
      <Derived>
        <Switch>
          <Case>
            <When>
              <Dependency path="/isFilingStatusMFJ"/>
            </When>
            <Then>
              <String>Married Filing Jointly</String>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isFilingStatusMFS"/>
            </When>
            <Then>
              <String>Married Filing Separately</String>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isFilingStatusSingle"/>
            </When>
            <Then>
              <String>Single</String>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isFilingStatusHOH"/>
            </When>
            <Then>
              <String>Head of Household</String>
            </Then>
          </Case>
          <Case>
            <When>
              <Dependency path="/isFilingStatusQSS"/>
            </When>
            <Then>
              <String>Qualifying Surviving Spouse</String>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/derivedFilingStatus">
      <Derived>
        <Switch>
          <Case>
            <When>
              <All>
                <Dependency path="/tentativelyHOHFromHomeUpkeep"/>
                <Any>
                  <Dependency path="/isSingle"/>
                  <Dependency path="/isDivorcedOrLegallySeparated"/>
                  <Dependency path="/isWidowedAtLeastTwoTaxYearsAgo"/>
                  <All>
                    <Dependency path="/isWidowedInPastTwoTaxYears"/>
                    <IsComplete>
                      <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
                    </IsComplete>
                    <Not>
                      <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
                    </Not>
                  </All>
                  <All>
                    <Dependency path="/isWidowedInPastTwoTaxYears"/>
                    <Not>
                      <Dependency path="/entitledToPreviouslyFileJointReturn"/>
                    </Not>
                  </All>
                  <All>
                    <Dependency path="/isWidowedInPastTwoTaxYears"/>
                    <Dependency path="/entitledToPreviouslyFileJointReturn"/>
                    <Not>
                      <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
                    </Not>
                  </All>
                </Any>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">headOfHousehold</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <All>
                <Not>
                  <Dependency path="/tentativelyHOHFromHomeUpkeep"/>
                </Not>
                <Any>
                  <Dependency path="/isSingle"/>
                  <Dependency path="/isDivorcedOrLegallySeparated"/>
                  <Dependency path="/isWidowedAtLeastTwoTaxYearsAgo"/>
                  <All>
                    <Dependency path="/isWidowedInPastTwoTaxYears"/>
                    <IsComplete>
                      <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
                    </IsComplete>
                    <Not>
                      <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
                    </Not>
                  </All>
                  <All>
                    <Dependency path="/isWidowedInPastTwoTaxYears"/>
                    <Not>
                      <Dependency path="/entitledToPreviouslyFileJointReturn"/>
                    </Not>
                  </All>
                  <All>
                    <Dependency path="/isWidowedInPastTwoTaxYears"/>
                    <Dependency path="/entitledToPreviouslyFileJointReturn"/>
                    <Not>
                      <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
                    </Not>
                  </All>
                </Any>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">single</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <All>
                <Dependency path="/maritalStatusAllowsFilingMarried"/>
                <Dependency path="/intendsToFileJointly"/>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">marriedFilingJointly</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <All>
                <Dependency path="/maritalStatusAllowsFilingMarried"/>
                <Not>
                  <Dependency path="/intendsToFileJointly"/>
                </Not>
                <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">marriedFilingSeparately</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <All>
                <Dependency path="/maritalStatusAllowsFilingMarried"/>
                <Not>
                  <All>
                    <Dependency path="/intendsToFileJointly"/>
                    <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
                  </All>
                </Not>
                <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">headOfHousehold</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <All>
                <Dependency path="/maritalStatusAllowsFilingMarried"/>
                <Not>
                  <Dependency path="/intendsToFileJointly"/>
                </Not>
                <Not>
                  <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
                </Not>
                <Not>
                  <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
                </Not>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">marriedFilingSeparately</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <All>
                <Dependency path="/isWidowedInTaxYear"/>
                <Not>
                  <Dependency path="/intendsToFileJointly"/>
                </Not>
                <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">marriedFilingSeparately</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <Any>
                <All>
                  <Dependency path="/isWidowedInPastTwoTaxYears"/>
                  <Dependency path="/entitledToPreviouslyFileJointReturn"/>
                  <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
                  <Dependency path="/canClaimChildAsDependentInCurrentTaxYear"/>
                </All>
                <All>
                  <Dependency path="/isWidowedAtLeastTwoTaxYearsAgo"/>
                  <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
                </All>
              </Any>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">qualifiedSurvivingSpouse</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <Any>
                <All>
                  <Dependency path="/isWidowedInPastTwoTaxYears"/>
                  <Dependency path="/entitledToPreviouslyFileJointReturn"/>
                  <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
                  <Not>
                    <Dependency path="/canClaimChildAsDependentInCurrentTaxYear"/>
                  </Not>
                  <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
                </All>
              </Any>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">qualifiedSurvivingSpouse</Enum>
            </Then>
          </Case>
          <Case>
            <When>
              <All>
                <Dependency path="/isWidowedInPastTwoTaxYears"/>
                <Not>
                  <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
                </Not>
              </All>
            </When>
            <Then>
              <Enum optionsPath="/filingStatusOptions">qualifiedSurvivingSpouse</Enum>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/isHOHMarried">
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/samePrincipalResidenceLast6Months">
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/flowShouldSeeAliveSecondaryValidSSN">
      <Derived>
        <Any>
          <Dependency path="/isInitialFilingStatusMFJ"/>
          <All>
            <Dependency path="/isFilingStatusMFJ"/>
            <Dependency path="/intendsToFileJointlyMFJ"/>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeSpouseAliveEndOfTaxYear">
      <Derived>
        <All>
          <Dependency path="/isWidowedInPastTwoTaxYears"/>
          <Not>
            <Dependency path="/entitledToPreviouslyFileJointReturn"/>
          </Not>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeSpouseAgeRange">
      <Derived>
        <All>
          <IsComplete>
            <Dependency path="/spouseAliveEndOfTaxYear"/>
          </IsComplete>
          <Dependency path="/isWidowedInPastTwoTaxYears"/>
          <Not>
            <Dependency path="/entitledToPreviouslyFileJointReturn"/>
          </Not>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeHalfOfHomeCosts">
      <Derived>
        <Any>
          <Dependency path="/entitledToPreviouslyFileJointReturn"/>
          <All>
            <Not>
              <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            </Not>
            <Any>
              <All>
                <Dependency path="/isMarried"/>
                <Not>
                  <Dependency path="/intendsToFileJointlyMFJ"/>
                </Not>
              </All>
              <All>
                <Dependency path="/isWidowedInTaxYear"/>
                <Not>
                  <Dependency path="/intendsToFileJointlyWidow"/>
                </Not>
              </All>
            </Any>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeHalfOfHomeCostsCanClaimChildAsDependentInCurrentTaxYear">
      <Derived>
        <All>
          <Dependency path="/entitledToPreviouslyFileJointReturn"/>
          <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeMartialQuestions">
      <Derived>
        <Any>
          <Dependency path="/isFilingStatusHOH"/>
          <Dependency path="/isMarried"/>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeSpouseSeparationTest">
      <Derived>
        <Any>
          <Dependency path="/isInitialFilingStatusHOHAndMarried"/>
          <Dependency path="/isInitialFilingStatusMFS"/>
          <Dependency path="/isHOHMarried"/>
          <All>
            <Dependency path="/isMarried"/>
            <Not>
              <Dependency path="/intendsToFileJointly"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isWidowedInTaxYear"/>
            <Not>
              <Dependency path="/intendsToFileJointlyWidow"/>
            </Not>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeSamePrincipalResidenceLast6Months">
      <Derived>
        <All>
          <Dependency path="/isFilingStatusComplete"/>
          <Dependency path="/isFilingStatusMFS"/>
          <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
          <Any>
            <All>
              <Dependency path="/isMarried"/>
              <Not>
                <Dependency path="/intendsToFileJointlyMFJ"/>
              </Not>
            </All>
            <All>
              <Dependency path="/isWidowedInTaxYear"/>
              <Not>
                <Dependency path="/intendsToFileJointlyWidow"/>
              </Not>
            </All>
          </Any>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeWritableSeparationAgreement">
      <Derived>
        <Any>
          <Dependency path="/samePrincipalResidenceLast6Months"/>
          <All>
            <Dependency path="/isInitialFilingStatusMFS"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
          </All>
          <All>
            <Dependency path="/isHOHMarried"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
          </All>
          <All>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Any>
                <All>
                  <Dependency path="/isMarried"/>
                  <Not>
                    <Dependency path="/intendsToFileJointlyMFJ"/>
                  </Not>
                </All>
                <All>
                  <Dependency path="/isWidowedInTaxYear"/>
                  <Not>
                    <Dependency path="/intendsToFileJointlyWidow"/>
                  </Not>
                </All>
              </Any>
            </Not>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeMaritalStatus">
      <Derived>
        <Any>
          <Dependency path="/isFilingStatusHOH"/>
          <Not>
            <Dependency path="/knowsFilingStatus"/>
          </Not>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/isDisqualifiedMarriedNotFilingJointly">
      <Name>Disqualified for EITC as Married Not Filing Jointly</Name>
      <Description>True if the taxpayer is married filing separately or HOH but does not meet the residency or legal separation requirements to claim EITC. Can also be true if Filer is HOH and meets the preceding test, but is not claiming any qualifying children</Description>
      <Derived>
        <Any>
          <All>
            <Dependency path="/flowShouldSeeSpouseSeparationTest"/>
            <Not>
              <Dependency path="/isMarried"/>
            </Not>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Dependency path="/writableSeparationAgreement"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isInitialFilingStatusHOHAndMarried"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Dependency path="/writableSeparationAgreement"/>
            </Not>
            <Not>
              <Dependency path="/primaryFilerIsClaimingQualifyingChildren"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isFilingStatusMFS"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Dependency path="/writableSeparationAgreement"/>
            </Not>
            <Not>
              <Dependency path="/primaryFilerIsClaimingQualifyingChildren"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isFilingStatusMFS"/>
            <Dependency path="/samePrincipalResidenceLast6Months"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Dependency path="/writableSeparationAgreement"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isInitialFilingStatusMFS"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Dependency path="/writableSeparationAgreement"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isHOHMarried"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Dependency path="/writableSeparationAgreement"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isMarried"/>
            <Not>
              <Dependency path="/intendsToFileJointlyMFJ"/>
            </Not>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Dependency path="/samePrincipalResidenceLast6Months"/>
            <Dependency path="/writableSeparationAgreement"/>
            <Not>
              <Dependency path="/primaryFilerIsClaimingQualifyingChildren"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isWidowedInTaxYear"/>
            <Not>
              <Dependency path="/intendsToFileJointlyWidow"/>
            </Not>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Dependency path="/samePrincipalResidenceLast6Months"/>
            <Dependency path="/writableSeparationAgreement"/>
            <Not>
              <Dependency path="/primaryFilerIsClaimingQualifyingChildren"/>
            </Not>
          </All>
          <All>
            <Dependency path="/isWidowedInTaxYear"/>
            <Dependency path="/spouseLivedWithTaxpayerLastSixMonths"/>
            <Not>
              <Dependency path="/intendsToFileJointlyWidow"/>
            </Not>
            <Not>
              <Dependency path="/samePrincipalResidenceLast6Months"/>
            </Not>
            <Not>
              <Dependency path="/primaryFilerIsClaimingQualifyingChildren"/>
            </Not>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/yearOfSpouseDeathOptions">
      <Name>Year of Spouse Death Options</Name>
      <Description>The year that a taxpayer's spouse died</Description>
      <Derived>
        <EnumOptions>
          <String>taxYear</String>
          <String>taxYearMinusOneOrTwo</String>
          <String>beforeTaxYearMinusTwo</String>
        </EnumOptions>
      </Derived>
    </Fact>
    <Fact path="/yearOfSpouseDeathCurrentTaxYearIsChosen">
      <Writable>
        <Enum optionsPath="/yearOfSpouseDeathOptions"/>
      </Writable>
    </Fact>
    <Fact path="/yearOfSpouseDeathLastTaxYearIsChosen">
      <Writable>
        <Enum optionsPath="/yearOfSpouseDeathOptions"/>
      </Writable>
    </Fact>
    <Fact path="/yearOfSpouseDeathTwoTaxYearsAgoIsChosen">
      <Writable>
        <Enum optionsPath="/yearOfSpouseDeathOptions"/>
      </Writable>
    </Fact>
    <Fact path="/yearOfSpouseDeath">
      <Name>Year of spouse's death</Name>
      <Description>The relative year a widowed filer's spouse died.</Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/yearOfSpouseDeathCurrentTaxYearIsChosen"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/yearOfSpouseDeathCurrentTaxYearIsChosen"/>
            </Then>
          </Case>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/yearOfSpouseDeathLastTaxYearIsChosen"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/yearOfSpouseDeathLastTaxYearIsChosen"/>
            </Then>
          </Case>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/yearOfSpouseDeathTwoTaxYearsAgoIsChosen"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/yearOfSpouseDeathTwoTaxYearsAgoIsChosen"/>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/isWidowedInTaxYear">
      <Name>Is (really Was) Widowed in Tax Year</Name>
      <Description>Was the filer widowed in the current tax year?</Description>
      <Derived>
        <All>
          <Dependency path="/isWidowed"/>
          <Equal>
            <Left>
              <Dependency path="/yearOfSpouseDeath"/>
            </Left>
            <Right>
              <Enum optionsPath="/yearOfSpouseDeathOptions">taxYear</Enum>
            </Right>
          </Equal>
        </All>
      </Derived>
    </Fact>
    <Fact path="/isWidowedInPastTwoTaxYears">
      <Derived>
        <All>
          <Dependency path="/isWidowed"/>
          <Equal>
            <Left>
              <Dependency path="/yearOfSpouseDeath"/>
            </Left>
            <Right>
              <Enum optionsPath="/yearOfSpouseDeathOptions">taxYearMinusOneOrTwo</Enum>
            </Right>
          </Equal>
        </All>
      </Derived>
    </Fact>
    <Fact path="/isWidowedAtLeastTwoTaxYearsAgo">
      <Derived>
        <All>
          <Dependency path="/isWidowed"/>
          <Equal>
            <Left>
              <Dependency path="/yearOfSpouseDeath"/>
            </Left>
            <Right>
              <Enum optionsPath="/yearOfSpouseDeathOptions">beforeTaxYearMinusTwo</Enum>
            </Right>
          </Equal>
        </All>
      </Derived>
    </Fact>
    <Fact path="/maritalStatusAllowsFilingMarried">
      <Name>Marital status allows filing married</Name>
      <Description>The TP's declared marital status (either married or widowed in tax year) allows them to file as QSS
        or MFJ.</Description>
      <Derived>
        <Any>
          <Dependency path="/isMarried"/>
          <Dependency path="/isWidowedInTaxYear"/>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeDeceasedSpouseJointReturnIntent">
      <Derived>
        <All>
          <Dependency path="/isWidowedInTaxYear"/>
          <Not>
            <Dependency path="/knowsFilingStatus"/>
          </Not>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeMFJJointReturnIntent">
      <Derived>
        <All>
          <Dependency path="/isMarried"/>
          <Not>
            <Dependency path="/knowsFilingStatus"/>
          </Not>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowShouldSeeTentativeHOHHomeUpkeepScenario">
      <Derived>
        <All>
          <Not>
            <Dependency path="/knowsFilingStatus"/>
          </Not>
          <Any>
            <Dependency path="/isSingle"/>
            <Dependency path="/isDivorcedOrLegallySeparated"/>
            <Dependency path="/isWidowedAtLeastTwoTaxYearsAgo"/>
            <All>
              <Dependency path="/isWidowedInPastTwoTaxYears"/>
              <Dependency path="/entitledToPreviouslyFileJointReturn"/>
              <Not>
                <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
              </Not>
            </All>
            <All>
              <Dependency path="/isWidowedInPastTwoTaxYears"/>
              <Not>
                <Dependency path="/entitledToPreviouslyFileJointReturn"/>
              </Not>
            </All>
            <All>
              <Dependency path="/isWidowedInPastTwoTaxYears"/>
              <Dependency path="/entitledToPreviouslyFileJointReturn"/>
              <Not>
                <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
              </Not>
              <Not>
                <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
              </Not>
            </All>
            <All>
              <Dependency path="/isWidowedInPastTwoTaxYears"/>
              <Dependency path="/entitledToPreviouslyFileJointReturn"/>
              <Dependency path="/paidMoreThanHalfHomeCostsForChild"/>
              <Not>
                <Dependency path="/canClaimChildAsDependentInCurrentTaxYear"/>
              </Not>
              <Not>
                <Dependency path="/couldClaimChildAsDependentInCurrentTaxYearWithExceptions"/>
              </Not>
            </All>
          </Any>
        </All>
      </Derived>
    </Fact>
    <Fact path="/eligibleForMFJ">
      <Name>Eligible for joint return</Name>
      <Description>
        Whether the taxpayer is eligible to file jointly. This requires them being married or widowed during
        their tax year and the spouse must meet appropriate residency requirements.
      </Description>
      <Derived>
        <All>
          <Dependency path="/maritalStatusAllowsFilingMarried"/>
          <Dependency module="filers" path="/secondaryFilerResidencyEligibleForMFJ"/>
        </All>
      </Derived>
    </Fact>
    <Fact path="/eligibleForMFS">
      <Name>Eligible to file as MFS</Name>
      <Description>The TP is eligible to file as MFS</Description>
      <Derived>
        <Dependency path="/maritalStatusAllowsFilingMarried"/>
      </Derived>
    </Fact>
    <Fact path="/eligibleForSingle">
      <Name>Eligible to file as single</Name>
      <Description>The TP is eligible to file as single</Description>
      <Derived>
        <Not>
          <Dependency path="/maritalStatusAllowsFilingMarried"/>
        </Not>
      </Derived>
    </Fact>
    <Fact path="/eligibleForHoh">
      <Name>Eligible for Head of Household</Name>
      <Description>Whether the taxpayer is eligible for Head of Household filing status.</Description>
      <Derived>
        <All>
          <GreaterThan>
            <Left>
              <Count>
                <Dependency module="familyAndHousehold" path="/familyAndHousehold/*/hohQualifyingPerson"/>
              </Count>
            </Left>
            <Right>
              <Int>0</Int>
            </Right>
          </GreaterThan>
          <Dependency module="filers" path="/filerCouldQualifyForHoh"/>
          <!-- Filers who are eligible for QSS are not eligible for HOH, preventing them from taking a less
               advantageous refund 26 U.S.C. § 2(b)(1) -->
          <Not>
            <Dependency path="/eligibleForQss"/>
          </Not>
        </All>
      </Derived>
    </Fact>
    <Fact path="/eligibleForQss">
      <Name>Eligible for Qualified Surviving Spouse</Name>
      <Description>Whether the taxpayer is eligible for Qualified Surviving Spouse filing status.</Description>
      <Derived>
        <All>
          <Dependency module="filers" path="/filerCouldQualifyForQss"/>
          <GreaterThan>
            <Left>
              <Count>
                <Dependency module="familyAndHousehold" path="/familyAndHousehold/*/qssQualifyingPerson"/>
              </Count>
            </Left>
            <Right>
              <Int>0</Int>
            </Right>
          </GreaterThan>
        </All>
      </Derived>
    </Fact>
    <Fact path="/treatAsMFJ">
      <Name>Treat as MFJ</Name>
      <Description>Treat the TP as MFJ. They have either declared an MFJ filing status, or are attempting for an MFJ
        filing status</Description>
      <Derived>
        <Any>
          <All>
            <IsComplete>
              <Dependency path="/filingStatus"/>
            </IsComplete>
            <!-- The TP is filing a joint return -->
            <Dependency path="/isFilingStatusMFJ"/>
            <Dependency path="/eligibleForMFJ"/>
          </All>
          <All>
            <!-- or the TP is trying for a joint return, but hasn't yet declared their filing
            status. -->
            <Not>
              <IsComplete>
                <Dependency path="/filingStatus"/>
              </IsComplete>
            </Not>
            <Dependency path="/wantsJointReturn"/>
            <Dependency path="/eligibleForMFJ"/>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/treatAsMFS">
      <Description>Treat the TP as MFS. They have either declared an MFS filing status, or are attempting for an MFS
        filing status</Description>
      <Derived>
        <Any>
          <All>
            <IsComplete>
              <Dependency path="/filingStatus"/>
            </IsComplete>
            <!-- The TP is filing a separate return -->
            <Dependency path="/isFilingStatusMFS"/>
          </All>
          <All>
            <!-- or the TP is trying for a separate return, but hasn't yet declared their filing
            status. -->
            <Not>
              <IsComplete>
                <Dependency path="/filingStatus"/>
              </IsComplete>
            </Not>
            <Dependency path="/wantsSeparateReturn"/>
            <Dependency path="/eligibleForMFS"/>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/treatAsHoh">
      <Description>Treat the TP as HoH. They have either declared an Hoh filing status, or are attempting for an HoH
        filing status</Description>
      <Derived>
        <Any>
          <All>
            <IsComplete>
              <Dependency path="/filingStatus"/>
            </IsComplete>
            <Dependency path="/isFilingStatusHOH"/>
          </All>
          <All>
            <Not>
              <IsComplete>
                <Dependency path="/filingStatus"/>
              </IsComplete>
            </Not>
            <Dependency path="/wantsHeadOfHousehold"/>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/wantsJointReturn">
      <Name>Wants joint return</Name>
      <Description>Whether the taxpayer wants to file jointly with their spouse.</Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/filingStatus"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/isFilingStatusMFJ"/>
            </Then>
          </Case>
          <Case>
            <When>
              <True/>
            </When>
            <Then>
              <Equal>
                <Left>
                  <Dependency path="/filingStatus"/>
                </Left>
                <Right>
                  <Enum optionsPath="/filingStatusInitialOptions">wantsMarriedFilingJointly</Enum>
                </Right>
              </Equal>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/wantsSeparateReturn">
      <Name>Wants separate return</Name>
      <Description>Whether the taxpayer wants to file separately with their spouse.</Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/filingStatus"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/isFilingStatusMFS"/>
            </Then>
          </Case>
          <Case>
            <When>
              <True/>
            </When>
            <Then>
              <Equal>
                <Left>
                  <Dependency path="/filingStatus"/>
                </Left>
                <Right>
                  <Enum optionsPath="/filingStatusInitialOptions">wantsMarriedFilingSeparately</Enum>
                </Right>
              </Equal>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
    <Fact path="/wantsHeadOfHousehold">
      <Name>Wants head of household</Name>
      <Description>Whether the taxpayer wants to head of household status.</Description>
      <Derived>
        <Equal>
          <Left>
            <Dependency path="/filingStatus"/>
          </Left>
          <Right>
            <Enum optionsPath="/filingStatusInitialOptions">wantsToSeeIfTheyQualifyHeadOfHousehold</Enum>
          </Right>
        </Equal>
      </Derived>
    </Fact>
    <Fact path="/wantsJointReturn">
      <Name>Wants joint return</Name>
      <Description>Whether the taxpayer wants to file jointly with their spouse.</Description>
      <Derived>
        <Switch>
          <Case>
            <When>
              <IsComplete>
                <Dependency path="/filingStatus"/>
              </IsComplete>
            </When>
            <Then>
              <Dependency path="/isFilingStatusMFJ"/>
            </Then>
          </Case>
          <Case>
            <When>
              <True/>
            </When>
            <Then>
              <Equal>
                <Left>
                  <Dependency path="/filingStatus"/>
                </Left>
                <Right>
                  <Enum optionsPath="/filingStatusInitialOptions">wantsMarriedFilingJointly</Enum>
                </Right>
              </Equal>
            </Then>
          </Case>
        </Switch>
      </Derived>
    </Fact>
  </Facts>
</FactDictionaryModule>
