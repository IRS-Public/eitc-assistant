<?xml version="1.0"?>
<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/relationshipOptions">
      <Name>Relationship Options</Name>
      <Description>The IRS allowed relationship options for a qualifying child</Description>
      <Derived>
        <EnumOptions>
          <String>childStepFoster</String>
          <String>sibling</String>
          <String>descendant</String>
          <String>none</String>
        </EnumOptions>
      </Derived>
    </Fact>
    <Fact path="/ageRangeOptionsQC">
      <Name>Age Range Options</Name>
      <Description>Qualifying child age brackets</Description>
      <Derived>
        <EnumOptions>
          <String>under19</String>
          <String>between19And23</String>
          <String>over24</String>
        </EnumOptions>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/name">
      <Name>Name of child</Name>
      <Writable>
        <String/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/livedWithYouUS">
      <Name>Lived with you in the US</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/someoneElseCanClaim">
      <Name>Someone else can claim this child</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/isClaimingQCRegardless">
      <Name>Taxpayer is claiming this QC even though someone else can claim them</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/marriedFilingJointly">
      <Name>Child is filing a joint return</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/mfjForRefundOnly">
      <Name>Child is filing a joint return solely for the purposes of claiming a refund</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/isPermanentlyDisabled">
      <Name>Child is permanently and totally disabled</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/relationship">
      <Name>Child relationship to taxpayer</Name>
      <Writable>
        <Enum optionsPath="/relationshipOptions"/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/ageRange">
      <Name>Child age range</Name>
      <Writable>
        <Enum optionsPath="/ageRangeOptionsQC"/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/isFullTimeStudent">
      <Name>Child is full-time student</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/validSSN">
      <Name>Child has valid SSN</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/isQCYoungerThanSelfOrSpouse">
      <Name>Child is younger than self or spouse, if MFJ</Name>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/familyAndHousehold/*/canSomeoneElseClaimAndTPNotClaiming">
      <Derived>
        <All>
          <Dependency path="../someoneElseCanClaim"/>
          <Not>
            <Dependency path="../isClaimingQCRegardless"/>
          </Not>
        </All>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/flowShouldSeeStudentQuestion">
      <Derived>
        <Equal>
          <Left>
            <Dependency path="../ageRange"/>
          </Left>
          <Right>
            <Enum optionsPath="/ageRangeOptionsQC">between19And23</Enum>
          </Right>
        </Equal>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/flowShouldSeeAgeComparison">
      <Derived>
        <All>
          <Equal>
            <Left>
              <Dependency path="../ageRange"/>
            </Left>
            <Right>
              <Enum optionsPath="/ageRangeOptionsQC">under19</Enum>
            </Right>
          </Equal>
          <Any>
            <Equal>
              <Left>
                <Dependency path="/ageRange"/>
              </Left>
              <Right>
                <Enum optionsPath="/ageRangeOptions">under24</Enum>
              </Right>
            </Equal>
            <Equal>
              <Left>
                <Dependency path="/ageRangeSecondary"/>
              </Left>
              <Right>
                <Enum optionsPath="/ageRangeOptions">under24</Enum>
              </Right>
            </Equal>
          </Any>
        </All>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/flowShouldShowMFJFiling">
      <Derived>
        <Any>
          <Not>
            <Dependency path="../someoneElseCanClaim"/>
          </Not>
          <All>
            <IsComplete>
              <Dependency path="../isClaimingQCRegardless"/>
            </IsComplete>
            <Dependency path="../isClaimingQCRegardless"/>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/mfjFilingTest">
      <Derived>
        <Any>
          <Not>
            <Dependency path="../marriedFilingJointly"/>
          </Not>
          <All>
            <IsComplete>
              <Dependency path="../mfjForRefundOnly"/>
            </IsComplete>
            <Dependency path="../mfjForRefundOnly"/>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/flowShouldShowDisability">
      <Derived>
        <Dependency path="../mfjFilingTest"/>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/flowShouldShowRelationship">
      <Derived>
        <IsComplete>
          <Dependency path="../isPermanentlyDisabled"/>
        </IsComplete>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/flowShouldShowValidSSN">
      <Derived>
        <Any>
          <All>
            <Dependency path="../isPermanentlyDisabled"/>
            <Dependency path="../meetsRelationshipTest"/>
          </All>
          <All>
            <IsComplete>
              <Dependency path="../mfjForRefundOnly"/>
            </IsComplete>
            <Dependency path="../mfjForRefundOnly"/>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/meetsRelationshipTest">
      <Derived>
        <Not>
          <Equal>
            <Left>
              <Dependency path="../relationship"/>
            </Left>
            <Right>
              <Enum optionsPath="/relationshipOptions">none</Enum>
            </Right>
          </Equal>
        </Not>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/meetsAgeTestDisability">
      <Derived>
        <Any>
          <Dependency path="../isPermanentlyDisabled"/>
          <Equal>
            <Left>
              <Dependency path="../ageRange"/>
            </Left>
            <Right>
              <Enum optionsPath="/ageRangeOptionsQC">under19</Enum>
            </Right>
          </Equal>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/meetsAgeTestStudent">
      <Derived>
        <All>
          <Equal>
            <Left>
              <Dependency path="../ageRange"/>
            </Left>
            <Right>
              <Enum optionsPath="/ageRangeOptionsQC">between19And23</Enum>
            </Right>
          </Equal>
          <Dependency path="../isFullTimeStudent"/>
        </All>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/meetsAgeTest">
      <Derived>
        <Any>
          <Dependency path="../meetsAgeTestDisability"/>
          <Dependency path="../meetsAgeTestStudent"/>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/isTentativeEitcQualifyingChild">
      <Name>Is an EITC Qualifying Child without asking about SSN (yet) </Name>
      <Derived>
        <All>
          <Dependency path="../livedWithYouUS"/>
          <Not>
            <Dependency path="../canSomeoneElseClaimAndTPNotClaiming"/>
          </Not>
          <Dependency path="../mfjFilingTest"/>
          <Dependency path="../meetsAgeTest"/>
          <Dependency path="../meetsRelationshipTest"/>
        </All>
      </Derived>
    </Fact>
    <Fact path="/familyAndHousehold/*/isEitcQualifyingChild">
      <Name>Is an EITC Qualifying Child</Name>
      <Description>True if the child passes all criteria to be counted as a qualifying child for the EITC.</Description>
      <Derived>
        <All>
          <Dependency path="../isTentativeEitcQualifyingChild"/>
          <Dependency path="../validSSN"/>
        </All>
      </Derived>
    </Fact>
    <Fact path="/countEitcQualifyingChildren">
      <Derived>
        <Count>
          <Dependency path="/familyAndHousehold/*/isEitcQualifyingChild"/>
        </Count>
      </Derived>
    </Fact>
    <Fact path="/hasEitcQualifyingChildren">
      <Derived>
        <GreaterThan>
          <Left>
            <Dependency path="/countEitcQualifyingChildren"/>
          </Left>
          <Right>
            <Int>0</Int>
          </Right>
        </GreaterThan>
      </Derived>
    </Fact>
    <Fact path="/flowShouldAllowAddAnotherQualifyingChild">
      <Name>QC flow: allow Add another child while fewer than max EITC qualifying children</Name>
      <Description>
        True when the raw count of /familyAndHousehold members who are EITC qualifying children is still below
        /maxNumberOfEitcQcs (3), or when that count is not yet complete so the user is not blocked mid-edit.
        Used to enable the Qualifying Children collection add button; when three successful EITC QCs are already
        counted, adding more rows is disabled (EITC does not increase past the third QC).
      </Description>
      <Derived>
        <Any>
          <Not>
            <IsComplete>
              <Dependency path="/countEitcQualifyingChildren"/>
            </IsComplete>
          </Not>
          <LessThan>
            <Left>
              <Dependency path="/countEitcQualifyingChildren"/>
            </Left>
            <Right>
              <Dependency path="/maxNumberOfEitcQcs"/>
            </Right>
          </LessThan>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowFamilyAndHouseholdEmptyForQcGating">
      <Name>QC flow: household has no member rows (unset or empty collection)</Name>
      <Description>
        True when /familyAndHousehold is not yet complete in the graph, or is complete with zero UUIDs. Used so
        Qualifying Children knockouts do not require client-side initialization of an empty Collection.
      </Description>
      <Derived>
        <Any>
          <Not>
            <IsComplete>
              <Dependency path="/familyAndHousehold"/>
            </IsComplete>
          </Not>
          <All>
            <IsComplete>
              <Dependency path="/familyAndHousehold"/>
            </IsComplete>
            <Equal>
              <Left>
                <CollectionSize>
                  <Dependency path="/familyAndHousehold"/>
                </CollectionSize>
              </Left>
              <Right>
                <Int>0</Int>
              </Right>
            </Equal>
          </All>
        </Any>
      </Derived>
    </Fact>
    <Fact path="/flowCohortEitcRequiresQualifyingChildEntry">
      <Name>Flow cohort: must have an EITC qualifying child when claiming QC (Single/QSS/MFJ age; MFS; married HOH)</Name>
      <Description>
        True when the taxpayer completed and answered yes to claiming EITC qualifying children, and any of:
        (1) Single, QSS, or MFJ and outside the 25&#x2013;64 age band for EITC without a qualifying child
        (same basis as /failsEitcAgeBandWithoutQualifyingChildren); (2) Married Filing Separately; or
        (3) Head of Household and married (considered married for HOH). MFS and married HOH cannot use EITC
        without a qualifying child under flow rules and must enter at least one EITC QC story on Qualifying Children.
      </Description>
      <Derived>
        <All>
          <IsComplete>
            <Dependency path="/primaryFilerIsClaimingQualifyingChildren"/>
          </IsComplete>
          <Dependency path="/primaryFilerIsClaimingQualifyingChildren"/>
          <Any>
            <All>
              <Any>
                <Dependency path="/isFilingStatusSingle"/>
                <Dependency path="/isFilingStatusQSS"/>
                <Dependency path="/isFilingStatusMFJ"/>
              </Any>
              <Dependency path="/failsEitcAgeBandWithoutQualifyingChildren"/>
            </All>
            <Dependency path="/isFilingStatusMFS"/>
            <All>
              <Dependency path="/isFilingStatusHOH"/>
              <Dependency path="/isHOHMarried"/>
            </All>
          </Any>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowShouldShowQcRequiredAddChildKnockout">
      <Name>Show QC flow knockout: add a child (empty household)</Name>
      <Description>
        True when the cohort must enter at least one qualifying child for EITC, the household list is still empty,
        and there are no EITC qualifying children yet.
      </Description>
      <Derived>
        <All>
          <Dependency path="/flowCohortEitcRequiresQualifyingChildEntry"/>
          <Dependency path="/flowFamilyAndHouseholdEmptyForQcGating"/>
          <Not>
            <Dependency path="/hasEitcQualifyingChildren"/>
          </Not>
        </All>
      </Derived>
    </Fact>
    <Fact path="/flowClickedNextOnQualifyingChildrenPage">
      <Name>User clicked Next on Qualifying Children page</Name>
      <Description>
        Set in the browser when the user clicks Continue from Qualifying Children while the add-child required-QC
        knockout condition is true, so that page-level knockout does not show on initial page load.
      </Description>
      <Writable>
        <Boolean/>
      </Writable>
    </Fact>
    <Fact path="/flowShouldShowQcRequiredAddChildKnockoutAfterContinue">
      <Name>Show QC add-child knockout after Continue</Name>
      <Description>
        Wraps /flowShouldShowQcRequiredAddChildKnockout and only shows it after Continue has been clicked on
        Qualifying Children.
      </Description>
      <Derived>
        <All>
          <Dependency path="/flowShouldShowQcRequiredAddChildKnockout"/>
          <Dependency path="/flowClickedNextOnQualifyingChildrenPage"/>
        </All>
      </Derived>
    </Fact>
  </Facts>
</FactDictionaryModule>
